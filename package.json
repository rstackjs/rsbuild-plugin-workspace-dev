{
  "name": "rsbuild-plugin-workspace-dev",
  "version": "1.0.0",
  "description": "An Rsbuild plugin to provides workspace recursive dev functionality for Monorepo topologies.",
  "repository": "https://github.com/rstackjs/rsbuild-plugin-workspace-dev",
  "homepage": "https://github.com/rstackjs/rsbuild-plugin-workspace-dev#readme",
  "bugs": {
    "url": "https://github.com/rstackjs/rsbuild-plugin-workspace-dev/issues"
  },
  "license": "MIT",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "rslib",
    "bump": "npx bumpp",
    "dev": "rslib -w",
    "lint": "rslint && prettier -c .",
    "lint:write": "rslint --fix && prettier -w .",
    "prepare": "simple-git-hooks",
    "test": "rstest --config=./test/rstest.config.ts",
    "test:e2e": "rstest --config=./test/rstest.config.ts --project=e2e",
    "test:unit": "rstest --config=./test/rstest.config.ts --project=unit"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm run lint:write"
  },
  "dependencies": {
    "@manypkg/get-packages": "^3.1.0",
    "chalk": "^5.6.2",
    "graphlib": "^2.1.8",
    "json5": "^2.2.3"
  },
  "devDependencies": {
    "@rsbuild/core": "^2.1.2",
    "@rsbuild/plugin-react": "^2.1.0",
    "@rsbuild/plugin-type-check": "^1.5.0",
    "@rslib/core": "^0.23.1",
    "@rslint/core": "^0.6.4",
    "@rstest/core": "^0.11.1",
    "@rstest/playwright": "^0.11.1",
    "@types/graphlib": "^2.1.12",
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "playwright": "^1.61.1",
    "prettier": "^3.9.4",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "simple-git-hooks": "^2.13.1",
    "typescript": "^7.0.2"
  },
  "peerDependencies": {
    "@rsbuild/core": "^1.0.0 || ^2.0.0"
  },
  "peerDependenciesMeta": {
    "@rsbuild/core": {
      "optional": true
    }
  },
  "packageManager": "pnpm@11.9.0",
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  }
}
